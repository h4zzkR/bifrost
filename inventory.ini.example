# ============================================================
#  Bifrost — inventory is now secrets.yaml
#
#  The project uses a single YAML inventory file that doubles
#  as an ansible-vault secrets vault. See secrets.yaml.example.
#
#  Quick start:
#    cp secrets.yaml.example secrets.yaml
#    # fill in IPs, passwords, domain
#    ansible-vault encrypt secrets.yaml
#    ansible-playbook -i secrets.yaml playbook-foreign.yaml --ask-vault-pass
#    ansible-playbook -i secrets.yaml playbook-relay.yaml   --ask-vault-pass
# ============================================================
