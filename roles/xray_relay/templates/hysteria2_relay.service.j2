[Unit]
Description=Hysteria2 Client (relay exit node)
After=network.target

[Service]
Type=simple
Restart=on-failure
RestartSec=10
WorkingDirectory={{ hysteria2_path }}
ExecStart={{ (hysteria2_path, 'hysteria') | path_join }} client -c {{ (hysteria2_path, 'relay_client.yaml') | path_join }}

[Install]
WantedBy=multi-user.target
