{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "tag": "vless-vision",
      "settings": {
        "clients": [
          {
            "id": "{{ xray.uuid }}",
            "flow": "xtls-rprx-vision",
            "testseed": [900, 500, 900, 256]
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "{{ xray_sni_dest }}:443",
          "xver": 0,
          "serverNames": [
            "{{ xray_sni_dest }}"
          ],
          "privateKey": "{{ xray.x25519_private }}",
          "minClientVer": "",
          "maxClientVer": "",
          "maxTimeDiff": 60000,
          "shortIds": ["{{ xray.short_id }}"],
          "limitFallbackUpload": {
            "afterBytes": 14000,
            "bytesPerSec": 102400,
            "burstBytesPerSec": 10485760
          },
          "limitFallbackDownload": {
            "afterBytes": 14000,
            "bytesPerSec": 2097152,
            "burstBytesPerSec": 52428800
          }
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"],
        "routeOnly": true
      }
    },
    {
      "port": {{ xray_xhttp_port | default(8443) }},
      "protocol": "vless",
      "tag": "vless-xhttp",
      "settings": {
        "clients": [
          {
            "id": "{{ xray.uuid }}"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "xhttpSettings": {
          "mode": "stream-one",
          "path": "/{{ xray.xhttp_path }}",
          "keepAliveInterval": 30
        },
        "realitySettings": {
          "show": false,
          "dest": "{{ xray_sni_dest }}:443",
          "xver": 0,
          "serverNames": [
            "{{ xray_sni_dest }}"
          ],
          "privateKey": "{{ xray.x25519_private }}",
          "minClientVer": "",
          "maxClientVer": "",
          "maxTimeDiff": 60000,
          "shortIds": ["{{ xray.short_id }}"],
          "limitFallbackUpload": {
            "afterBytes": 14000,
            "bytesPerSec": 102400,
            "burstBytesPerSec": 10485760
          },
          "limitFallbackDownload": {
            "afterBytes": 14000,
            "bytesPerSec": 2097152,
            "burstBytesPerSec": 52428800
          }
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"],
        "routeOnly": true
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct",
      "settings": {
        "domainStrategy": "UseIPv4"
      }
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ]
}
