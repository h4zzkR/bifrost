# Default catch-all — drop direct IP access
server {
    listen 80 default_server;
    return 444;
}

server {
    listen 80;
    server_name {{ webserver_domain }};
    root /var/www/{{ webserver_domain }};

    # Let's Encrypt webroot challenge
    location /.well-known/acme-challenge/ {
        root /var/www/{{ webserver_domain }};
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
