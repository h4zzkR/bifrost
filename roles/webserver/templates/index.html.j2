<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ webserver_domain }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f5f5f5;
      color: #333;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .container {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      padding: 60px 80px;
      text-align: center;
      max-width: 480px;
    }
    h1 { font-size: 1.8rem; font-weight: 600; margin-bottom: 12px; }
    p  { color: #666; line-height: 1.6; }
    .domain { color: #888; font-size: 0.9rem; margin-top: 32px; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Welcome</h1>
    <p>This site is currently under construction.<br>Check back soon.</p>
    <p class="domain">{{ webserver_domain }}</p>
  </div>
</body>
</html>
