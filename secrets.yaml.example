# ============================================================
#  Bifrost — secrets.yaml
#
#  This file is BOTH the Ansible inventory AND the secrets vault.
#  One file to fill in, one file to encrypt.
#
#  Setup:
#    1. cp secrets.yaml.example secrets.yaml
#    2. Fill in your values (search for REPLACE_ME).
#    3. ansible-vault encrypt secrets.yaml
#
#  Run foreign VPS setup (step 1):
#    ansible-playbook -i secrets.yaml playbook-foreign.yaml --ask-vault-pass
#
#  Run relay VPS setup (step 2, after foreign is done):
#    ansible-playbook -i secrets.yaml playbook-relay.yaml --ask-vault-pass
#
#  Rollback (run with hardened SSH port + key):
#    ansible-playbook -i secrets.yaml playbook-rollback.yaml --ask-vault-pass \
#      -e "ansible_port=42228 ansible_user=vpnuser" \
#      -e "ansible_ssh_private_key_file=~/.ssh/id_vps"
# ============================================================

all:
  children:

    # ── Foreign (overseas) VPS ────────────────────────────────────────────
    foreign:
      hosts:
        foreign-vps:
          ansible_host:        "REPLACE_ME"   # e.g. 1.2.3.4
          ansible_user:        root
          ansible_ssh_pass:    "REPLACE_ME"   # root password
          ansible_become_pass: "REPLACE_ME"   # same as above
          ansible_connection:  ssh

    # ── Russian relay VPS ─────────────────────────────────────────────────
    relay:
      hosts:
        relay-vps:
          ansible_host:        "REPLACE_ME"   # e.g. 5.6.7.8
          ansible_user:        root
          ansible_ssh_pass:    "REPLACE_ME"
          ansible_become_pass: "REPLACE_ME"
          ansible_connection:  ssh

  vars:

    # ── Foreign VPS: domain + TLS ─────────────────────────────────────────
    # DNS A-record for this domain must point to the foreign VPS IP.
    # Used as: nginx site, Xray REALITY SNI, Let's Encrypt TLS cert subject.
    foreign_domain: "REPLACE_ME"        # e.g. vpn.example.com
    certbot_email:  "REPLACE_ME"        # e.g. admin@example.com

    # ── Relay VPS: Russian domain + TLS ──────────────────────────────────
    # Your own Russian domain with DNS A-record pointing to the relay VPS IP.
    # Used as: nginx site, Xray REALITY SNI, Let's Encrypt TLS cert subject.
    # The relay gets a real cert — probers see a valid HTTPS site, not self-signed.
    relay_domain: "REPLACE_ME"         # e.g. relay.example.ru

    # ── SSH hardening (applied to both servers) ───────────────────────────
    ssh_port:            42228
    ssh_user:            "vpnuser"
    ssh_public_key_path: "~/.ssh/id_vps.pub"

    # Optional: set a password for the new SSH user (leave empty for key-only).
    ssh_user_password: ""

    # Optional: change the root password (leave empty to keep current).
    new_root_password: ""

    ssh_disable_password_auth: true
    ssh_disable_root_login:    true
